---
import Base from '../layouts/Base.astro';

const ctaHref = '#form';
const mailAddr = 'hello@ai-night.study';

const heroImage = '/assets/photo_2026-05-29_18-47-27.jpg';

const gallery = [
  '/assets/DSC05866.jpg',
  '/assets/DSC06251.jpg',
  '/assets/DSC07506.jpg',
  '/assets/DSC07784.jpg',
  '/assets/WhatsApp_Image_2026-03-20_at_19.16.32.jpg',
  '/assets/photo_2024-11-13_14-09-03.jpg',
  '/assets/photo_2025-01-25_14-56-46.jpg',
  '/assets/photo_2026-06-02_22-17-02.jpg',
];
const galleryLoop = [...gallery, ...gallery];

const journey = [
  {
    step: '01',
    head: '내 일 가져오기',
    body: '지난주에 손으로 쓴 보고서, 다음달 모집 공고, 매주 도는 정산표. 추상적인 예제가 아니라 본인 업무 파일을 들고 옵니다.',
  },
  {
    step: '02',
    head: '함께 만들기',
    body: '강사가 옆에서, 동기들이 옆에서. 코호트 단위로 같은 시간에 같은 문제를 푸는 야학 방식. 막힌 곳은 그 자리에서 풀어냅니다.',
  },
  {
    step: '03',
    head: '다음날 현장 적용',
    body: '강의실에서 만든 결과물은 다음날 사무실에서 그대로 씁니다. 강의 끝나면 사라지는 슬라이드가 아니라, 책상에 남는 도구를 만듭니다.',
  },
];

const programTracks = [
  {
    title: '지원사업 도전',
    body: '사업 아이템을 심사 언어로 정리합니다.',
    outputs: ['로컬 맞춤형 BM 분석', '정부지원사업 HWP 기획서 초안', '발표자료·심사 대응 문장'],
  },
  {
    title: '브랜드 콘텐츠',
    body: '매장과 상품을 바로 홍보할 콘텐츠로 바꿉니다.',
    outputs: ['인스타그램·블로그 발행 캘린더', '스마트폰 촬영 기반 숏폼 초안', '상세페이지·펀딩 스토리 구조'],
  },
  {
    title: 'AI 부사수',
    body: '혼자 반복하던 일을 맡길 AI 흐름을 만듭니다.',
    outputs: ['Notion·NotebookLM 업무 매뉴얼', '카카오톡 채널 FAQ 응대 흐름', '예약·위치·영업시간 반복 문의 자동화'],
  },
  {
    title: '정산·행정',
    body: '영수증과 보고서 사이의 시간을 줄입니다.',
    outputs: ['OCR 기반 영수증 정리', '지출 항목 분류', '결과보고서·정산보고서 초안'],
  },
  {
    title: '지역자원 상품화',
    body: '지역의 이야기와 공간을 체험 상품으로 만듭니다.',
    outputs: ['마을 아카이브 정리', '로컬 투어 동선 설계', '가이드 시나리오·체험 프로그램 초안'],
  },
];

const credentials = [
  {
    org: '남해 청년센터',
    role: '지역 청년 AI 워크숍',
  },
  {
    org: '경북시민재단',
    role: '시민사회 활동가 대상 AI 도입',
  },
  {
    org: '서울 사립대 / 공립 교사',
    role: '1:1 AI 과외 (재직자)',
  },
  {
    org: '모두의연구소',
    role: 'AI 교육 트랙 운영',
  },
  {
    org: 'Anthropic Courses',
    role: 'Claude 공식 코스 한국 번역·로컬라이즈',
  },
  {
    org: '테크 교육·행사 10년+',
    role: '커뮤니티·컨퍼런스 운영 경력',
  },
];

const quotes = [
  {
    body: 'AI에게 단순히 명령을 입력하는 것이 아니라, 원하는 결과를 얻기 위해 어떻게 질문하고 요청해야 하는지 배울 수 있었던 유익한 시간이었습니다. 그동안 AI가 어렵고 막연하게 느껴졌는데, 이번 강의를 통해 보다 친숙하게 다가갈 수 있었고 앞으로 실생활과 업무에도 적극 활용해보고 싶다는 생각이 들었습니다.',
    by: '경북시민재단 기획실 PM',
  },
];

const sections = [
  { id: 'difference', label: '방식' },
  { id: 'outputs', label: '프로그램' },
  { id: 'studio', label: '야학 풍경' },
  { id: 'voices', label: '후기' },
  { id: 'expertise', label: '진행자' },
  { id: 'form', label: '문의' },
];
---

<Base
  title="AI 야학 — 로컬 창업가를 위한 실무 AI 교육"
  description="로컬 창업가와 소상공인이 실제 사업 자료를 들고 와서 지원사업 기획서, SNS 콘텐츠, 고객 응대, AI 부사수를 만드는 실습형 AI 교육."
>
  <header class="masthead">
    <div class="masthead-inner">
      <a href="/" class="masthead__wordmark">AI 야학</a>
      <nav class="masthead__nav" aria-label="섹션 이동">
        {sections.slice(0, 5).map((s) => (
          <a href={`#${s.id}`}>{s.label}</a>
        ))}
      </nav>
      <a class="masthead__cta" href={ctaHref} data-ga="cta" data-loc="nav">교육 문의</a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__bg" role="img" aria-label="AI 야학 현장">
        <img src={heroImage} alt="" loading="eager" fetchpriority="high" />
        <div class="hero__veil"></div>
      </div>

      <div class="hero__inner">
        <span class="hero__eyebrow">AI 야학 · 로컬 창업 실습 프로그램</span>
        <h1 id="hero-title">
          로컬 창업가를 위한<br/>
          <em>AI 야학.</em>
        </h1>
        <p class="hero__sub">
          예비창업가와 소상공인이 실제 사업 자료를 들고 와서
          지원사업 기획서, SNS 콘텐츠, 고객 응대, AI 부사수를 만드는
          <strong>실습형 AI 교육</strong>입니다.
        </p>

        <div class="hero__cta">
          <a class="btn btn--primary" href={ctaHref} data-ga="cta" data-loc="hero">
            교육 과정 문의하기 →
          </a>
          <a class="btn btn--ghost" href="#difference" data-ga="learn" data-loc="hero">
            먼저 살펴보기
          </a>
        </div>
      </div>
    </section>

    <div class="shell">
      <!-- Difference -->
      <section id="difference" aria-labelledby="difference-title">
        <span class="eyebrow">No. 01 — 방식</span>
        <h2 id="difference-title">내 사업 자료로 시작해, 결과물로 끝납니다.</h2>
        <p class="lede">
          챗GPT 사용법을 배우는 시간이 아닙니다.
          참가자의 실제 사업 자료를 가져와서 강의실 안에서 결과물까지 만듭니다.
        </p>

        <ol class="journey">
          {journey.map((j) => (
            <li class="journey__step">
              <div class="journey__num">{j.step}</div>
              <h3>{j.head}</h3>
              <p>{j.body}</p>
            </li>
          ))}
        </ol>

        <p class="footnote">
          1일 워크숍도 가능하지만, 야학의 본 트랙은 <strong>같은 동료들과 3-4회 이상</strong> 만나는 코호트 과정입니다.
          처음 쓰는 사람도 따라올 수 있도록 실습과 피드백 시간을 넉넉히 둡니다.
        </p>
      </section>

      <!-- Outputs -->
      <section id="outputs" aria-labelledby="outputs-title">
        <span class="eyebrow">No. 02 — 프로그램</span>
        <h2 id="outputs-title">기관 사업 목적에 맞춰 5가지 트랙으로 묶습니다.</h2>
        <p class="lede">
          로컬 창업, 소상공인 디지털 전환, 로컬브랜드 고도화 사업에 맞춰
          필요한 트랙만 골라 1일 워크숍, 코호트, 마켓톤으로 설계합니다.
        </p>
        <ul class="program-grid">
          {programTracks.map((program, i) => (
            <li class="program-card">
              <div class="program-card__num">{String(i + 1).padStart(2, '0')}</div>
              <h3>{program.title}</h3>
              <p>{program.body}</p>
              <ul class="program-card__outputs">
                {program.outputs.map((output) => (
                  <li>{output}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
        <p class="footnote">
          기관의 사업명, 참여자 수준, 지역 산업군에 맞춰 다시 묶습니다.
          처음에는 참가자가 손에 쥐고 갈 결과물부터 정합니다.
        </p>
      </section>

    </div>

    <!-- Studio / gallery -->
    <section id="studio" class="studio" aria-labelledby="studio-title">
      <div class="studio__head">
        <span class="eyebrow eyebrow--dark">No. 03 — 풍경</span>
        <h2 id="studio-title">밤이 깊을수록, 손에 잡히는 것이 생긴다.</h2>
        <p>강의실 사진과 코호트 작업 풍경입니다.</p>
      </div>
      <div class="studio__carousel" id="studio-carousel" role="region" aria-label="강의 현장 사진">
        <div class="studio__track" aria-hidden="false">
          {galleryLoop.map((src, i) => (
            <figure class="studio__cell" aria-hidden={i >= gallery.length ? 'true' : 'false'}>
              <img src={src} alt="" loading={i < 4 ? 'eager' : 'lazy'} />
            </figure>
          ))}
        </div>
      </div>
      <div class="studio__controls" aria-label="사진 넘기기">
        <button type="button" class="studio__control" data-carousel-dir="-1" aria-label="이전 사진">←</button>
        <button type="button" class="studio__control" data-carousel-dir="1" aria-label="다음 사진">→</button>
      </div>
    </section>

    <div class="shell">
      <!-- Quotes -->
      <section id="voices" aria-labelledby="voices-title">
        <span class="eyebrow">No. 04 — 후기</span>
        <h2 id="voices-title">강의실을 나간 다음에 남는 것.</h2>

        <div class="quotes">
          {quotes.map((q) => (
            <figure class="quote">
              <blockquote>{q.body}</blockquote>
              <figcaption>— {q.by}</figcaption>
            </figure>
          ))}
        </div>
      </section>

      <!-- Expertise -->
      <section id="expertise" aria-labelledby="expertise-title">
        <span class="eyebrow">No. 05 — 진행자</span>
        <h2 id="expertise-title">로컬 현장에 맞춰 수업을 설계합니다.</h2>
        <p class="lede">
          로컬 창업가와 소상공인, 비전공자들을 위한 AI 교육 경험.
          각자의 사업 자료를 가져와도 따라올 수 있도록 강의보다 실습과 피드백 중심으로 운영합니다.
        </p>

        <ul class="creds">
          {credentials.map((c) => (
            <li class="cred">
              <div class="cred__org">{c.org}</div>
              <div class="cred__role">{c.role}</div>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Form -->
    <section id="form" class="form-section" aria-labelledby="form-title">
      <div class="form-shell">
        <span class="eyebrow eyebrow--dark">No. 06 — 문의</span>
        <h2 id="form-title">우리 기관에 맞는 과정으로 상담해 보세요.</h2>
        <p class="lede lede--dark">
          대상, 예산, 회차, 참가자 수준을 알려주시면 맞는 형태로 제안드립니다.
        </p>

        <form class="contact-form" onsubmit="return false;" aria-describedby="form-note">
          <label>
            <span>이름 / 직함</span>
            <input type="text" name="name" autocomplete="name" />
          </label>
          <label>
            <span>소속 기관·팀</span>
            <input type="text" name="org" autocomplete="organization" />
          </label>
          <label>
            <span>연락 받을 채널</span>
            <input type="text" name="contact" />
          </label>
          <label class="contact-form__full">
            <span>희망 과정이나 참가자 상황</span>
            <textarea name="pain" rows="3"></textarea>
          </label>

          <div class="contact-form__cta">
            <button type="submit" class="btn btn--primary btn--lg">맞춤 교육 문의 보내기</button>
            <a href={`mailto:${mailAddr}`} class="contact-form__alt" data-ga="mail" data-loc="form">
              또는 메일로 직접 보내기 →
            </a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <footer aria-labelledby="footer-title">
    <div class="footer-inner">
      <h2 id="footer-title">AI 야학</h2>
      <p class="footer-tag">
        로컬 창업가와 소상공인이 AI로 더 가볍게 일할 수 있도록.
      </p>
      <div class="footer-links">
        <a href="#form" data-ga="cta" data-loc="footer">교육 과정 문의하기</a>
        <a href={`mailto:${mailAddr}`} data-ga="mail" data-loc="footer">{mailAddr}</a>
      </div>
      <p class="footer-fine">
        AI 야학 · 2026 · 중간지원조직과 함께 로컬 창업가·소상공인을 위한 실습형 AI 교육을 운영합니다.
      </p>
    </div>
  </footer>

  <!-- Mobile sticky CTA -->
  <a href={ctaHref} class="sticky-cta" data-ga="cta" data-loc="sticky">
    교육 과정 문의하기 →
  </a>

  <script is:inline src="/studio-carousel.js" defer></script>
</Base>
