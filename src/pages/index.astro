---
import Base from '../layouts/Base.astro';

const ctaHref = '#form';
const mailAddr = 'hello@ai-night.study';

const heroImage = '/assets/photo_2025-07-10_19-07-18_2.jpg';

const gallery = [
  '/assets/photo_2025-07-10_19-07-18.jpg',
  '/assets/photo_2026-06-16_17-36-00.jpg',
  '/assets/WhatsApp_Image_2026-03-20_at_19.16.30.jpg',
  '/assets/photo_2025-01-25_14-56-46.jpg',
  '/assets/DSC05866.jpg',
  '/assets/photo_2026-06-02_22-17-02.jpg',
  '/assets/photo_2026-06-01_02-35-16.jpg',
  '/assets/photo_2024-11-13_14-09-03.jpg',
  '/assets/DSC07499.jpg',
  '/assets/DSC05669.jpg',
];
const galleryLoop = [...gallery, ...gallery];

const journey = [
  {
    step: '01',
    head: '내 일 가져오기',
    body: '지난주에 손으로 쓴 보고서, 다음달 모집 공고, 매주 도는 정산표. 추상적인 예제가 아니라 본인 업무 파일을 들고 옵니다.',
  },
  {
    step: '02',
    head: '함께 만들기',
    body: '강사가 옆에서, 동기들이 옆에서. 코호트 단위로 같은 시간에 같은 문제를 푸는 야학 방식. 막힌 곳은 그 자리에서 풀어냅니다.',
  },
  {
    step: '03',
    head: '다음날 현장 적용',
    body: '강의실에서 만든 결과물은 다음날 사무실에서 그대로 씁니다. 강의 끝나면 사라지는 슬라이드가 아니라, 책상에 남는 도구를 만듭니다.',
  },
];

const outputs = [
  '지원사업 신청서·결과보고서',
  'SNS 콘텐츠·카드뉴스',
  '정산·회계 보고',
  '고객·민원 응대',
  '모집글·상세 페이지',
  'AI 가상 비서 (업무용)',
];

const credentials = [
  {
    org: '남해 청년센터',
    role: '지역 청년 AI 워크숍',
  },
  {
    org: '경북시민재단',
    role: '시민사회 활동가 대상 AI 도입',
  },
  {
    org: '서울 사립대 / 공립 교사',
    role: '1:1 AI 과외 (재직자)',
  },
  {
    org: '모두의연구소',
    role: 'AI 교육 트랙 운영',
  },
  {
    org: 'Anthropic Courses',
    role: 'Claude 공식 코스 한국 번역·로컬라이즈',
  },
  {
    org: '테크 교육·행사 10년+',
    role: '커뮤니티·컨퍼런스 운영 경력',
  },
];

const quotes = [
  {
    body: '책상에서 매일 쓰던 양식을 그대로 들고 갔는데, 같은 양식을 30분 만에 끝내는 방법을 배웠다. 다음날 출근해서 바로 써봤다.',
    by: '서울 사립대 직원 · AI 과외 수강',
  },
  {
    body: '강의가 끝나도 결과물이 남는다. "이건 좋았는데 어떻게 다시 하지" 가 아니라, 만든 워크플로가 다음 회의에서 그대로 돌아간다.',
    by: '경북시민재단 사업 담당자',
  },
  {
    body: '지역에 와서 같이 만드는 느낌이었다. 일방적인 특강이 아니라, 다른 동기들이 막힌 데서 내가 배우는 야학.',
    by: '남해 청년센터 참여자',
  },
];

const sections = [
  { id: 'difference', label: '일반 특강과 다른 점' },
  { id: 'outputs', label: '만드는 결과물' },
  { id: 'expertise', label: '강사·기관 이력' },
  { id: 'voices', label: '수강생 후기' },
  { id: 'studio', label: '야학 풍경' },
  { id: 'form', label: '15분 제안 콜' },
];
---

<Base
  title="AI 야학 — 돈도 사람도 부족한 로컬 팀을 위한 AI"
  description="추상적인 AI 특강이 아니라, 본인 업무 파일을 들고 와서 다음날 현장에서 쓸 도구를 만들어 가는 코호트 학습. 공공·교육·로컬 팀을 위한 AI 야학."
>
  <header class="masthead">
    <div class="masthead-inner">
      <a href="/" class="masthead__wordmark">AI 야학</a>
      <nav class="masthead__nav" aria-label="섹션 이동">
        {sections.slice(0, 5).map((s) => (
          <a href={`#${s.id}`}>{s.label}</a>
        ))}
      </nav>
      <a class="masthead__cta" href={ctaHref} data-ga="cta" data-loc="nav">제안 콜</a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__bg" role="img" aria-label="AI 야학 현장">
        <img src={heroImage} alt="" loading="eager" fetchpriority="high" />
        <div class="hero__veil"></div>
      </div>

      <div class="hero__inner">
        <span class="hero__eyebrow">AI 야학 · 코호트 학습 프로그램</span>
        <h1 id="hero-title">
          돈도 사람도 부족한<br/>
          로컬 팀을 위한<br/>
          <em>AI 야학.</em>
        </h1>
        <p class="hero__sub">
          공공기관 주무관, 지역 활동가, 작은 학교 교직원, 1인 창업가.
          매주 같은 일을 손으로 처리하는 사람들을 위해, 본인의 업무 파일을 들고 와
          <strong>다음날 책상에서 쓸 도구</strong>를 함께 만들어 갑니다.
        </p>

        <div class="hero__cta">
          <a class="btn btn--primary" href={ctaHref} data-ga="cta" data-loc="hero">
            15분 제안 콜 잡기 →
          </a>
          <a class="btn btn--ghost" href="#difference" data-ga="learn" data-loc="hero">
            먼저 살펴보기
          </a>
        </div>

        <ul class="hero__meta" aria-label="대상">
          <li><span>대상</span> 공공·교육·로컬 팀</li>
          <li><span>형식</span> 3-6인 코호트, 2-4회차</li>
          <li><span>전제</span> 코딩 경험 불필요</li>
        </ul>
      </div>
    </section>

    <div class="shell">
      <!-- Difference -->
      <section id="difference" aria-labelledby="difference-title">
        <span class="eyebrow">No. 01 — 방법론</span>
        <h2 id="difference-title">일반 AI 특강과 다릅니다.</h2>
        <p class="lede">
          좋은 슬라이드를 보고 돌아와서 다시 막막해진 경험, 한 번쯤 있을 겁니다.
          AI 야학은 그 자리에서 본인 일을 끝내고 돌아갑니다.
        </p>

        <ol class="journey">
          {journey.map((j) => (
            <li class="journey__step">
              <div class="journey__num">{j.step}</div>
              <h3>{j.head}</h3>
              <p>{j.body}</p>
            </li>
          ))}
        </ol>

        <p class="footnote">
          1회성 특강도 가능하지만, 야학의 본 트랙은 <strong>같은 동료들과 4회차 이상</strong> 만나는 코호트 과정입니다.
          서로의 막힌 지점을 보는 게 학습 효율의 핵심입니다.
        </p>
      </section>

      <!-- Outputs -->
      <section id="outputs" aria-labelledby="outputs-title">
        <span class="eyebrow">No. 02 — 결과물</span>
        <h2 id="outputs-title">이런 것들을 만들고 갑니다.</h2>
        <p class="lede">
          매주 손으로 처리하던 업무. 코드 없이, AI가 옆에서 일하게 만드는 방식으로.
        </p>
        <ul class="chips">
          {outputs.map((o) => (
            <li class="chip">{o}</li>
          ))}
        </ul>
        <p class="footnote">
          기관 맞춤으로 결과물을 사전 설계합니다. 첫 콜에서 "지금 가장 손이 많이 가는 업무"부터 듣습니다.
        </p>
      </section>

      <!-- Expertise -->
      <section id="expertise" aria-labelledby="expertise-title">
        <span class="eyebrow">No. 03 — 전문성</span>
        <h2 id="expertise-title">기관 결재 라인에 안전하게 올릴 수 있는 강사.</h2>
        <p class="lede">
          AI 엔지니어가 아니라, 비전공자에게 눈높이를 맞추는 교육자.
          공공·교육·커뮤니티 현장에서 다음과 같이 일해 왔습니다.
        </p>

        <ul class="creds">
          {credentials.map((c) => (
            <li class="cred">
              <div class="cred__org">{c.org}</div>
              <div class="cred__role">{c.role}</div>
            </li>
          ))}
        </ul>
      </section>

      <!-- Quotes -->
      <section id="voices" aria-labelledby="voices-title">
        <span class="eyebrow">No. 04 — 현장의 말</span>
        <h2 id="voices-title">강의실을 나간 다음에 남는 것.</h2>

        <div class="quotes">
          {quotes.map((q) => (
            <figure class="quote">
              <blockquote>{q.body}</blockquote>
              <figcaption>— {q.by}</figcaption>
            </figure>
          ))}
        </div>
        <p class="footnote">인용은 모두 동의 받은 placeholder입니다. 실명·기관명은 협의 후 게재합니다.</p>
      </section>
    </div>

    <!-- Studio / gallery -->
    <section id="studio" class="studio" aria-labelledby="studio-title">
      <div class="studio__head">
        <span class="eyebrow eyebrow--dark">No. 05 — 야학 풍경</span>
        <h2 id="studio-title">밤이 깊을수록, 손에 잡히는 것이 생긴다.</h2>
        <p>강의실 사진과 코호트 작업 풍경입니다.</p>
      </div>
      <div class="studio__carousel" role="region" aria-label="강의 현장 사진">
        <div class="studio__track" aria-hidden="false">
          {galleryLoop.map((src, i) => (
            <figure class="studio__cell" aria-hidden={i >= gallery.length ? 'true' : 'false'}>
              <img src={src} alt="" loading={i < 4 ? 'eager' : 'lazy'} />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Form -->
    <section id="form" class="form-section" aria-labelledby="form-title">
      <div class="form-shell">
        <span class="eyebrow eyebrow--dark">No. 06 — 시작</span>
        <h2 id="form-title">15분만 통화해도 충분합니다.</h2>
        <p class="lede lede--dark">
          "지금 가장 손이 많이 가는 업무가 무엇인지" 한 가지만 들으면, 야학 트랙으로 풀 수 있는지 그 자리에서 답해 드립니다.
        </p>

        <form class="contact-form" onsubmit="event.preventDefault(); return false;" aria-describedby="form-note">
          <label>
            <span>이름 / 직함</span>
            <input type="text" name="name" placeholder="예: 김주무관 / 평생학습팀" autocomplete="name" />
          </label>
          <label>
            <span>소속 기관·팀</span>
            <input type="text" name="org" placeholder="예: ○○청년센터 / ○○대학교" autocomplete="organization" />
          </label>
          <label>
            <span>연락 받을 채널</span>
            <input type="text" name="contact" placeholder="이메일 또는 전화 (편하신 쪽)" />
          </label>
          <label class="contact-form__full">
            <span>지금 가장 손이 많이 가는 업무 한 줄</span>
            <textarea name="pain" rows="3" placeholder="예: 매주 정산 보고서 양식이 다 달라서 시간이 너무 듭니다."></textarea>
          </label>

          <div class="contact-form__cta">
            <button type="submit" class="btn btn--primary btn--lg">제안 콜 요청 보내기</button>
            <a href={`mailto:${mailAddr}`} class="contact-form__alt" data-ga="mail" data-loc="form">
              또는 메일로 직접 보내기 →
            </a>
          </div>
          <p id="form-note" class="contact-form__note">
            제출 시 별도 처리 없이 hello@ai-night.study 로 회신을 약속드립니다. 마케팅 수신·DB 저장 없음.
          </p>
        </form>
      </div>
    </section>
  </main>

  <footer aria-labelledby="footer-title">
    <div class="footer-inner">
      <h2 id="footer-title">AI 야학</h2>
      <p class="footer-tag">
        동아시아 로컬 팀이 AI로 더 오래 버틸 수 있도록.
      </p>
      <div class="footer-links">
        <a href="#form" data-ga="cta" data-loc="footer">15분 제안 콜 잡기</a>
        <a href={`mailto:${mailAddr}`} data-ga="mail" data-loc="footer">{mailAddr}</a>
      </div>
      <p class="footer-fine">
        AI 야학 · 2026 · 한국에서 비영리·공공·교육·로컬 팀을 위해 운영합니다.
      </p>
    </div>
  </footer>

  <!-- Mobile sticky CTA -->
  <a href={ctaHref} class="sticky-cta" data-ga="cta" data-loc="sticky">
    15분 제안 콜 잡기 →
  </a>
</Base>
