---
import Base from '../layouts/Base.astro';

const ctaHref = 'https://calendly.com/ai-night/15min';
const mailAddr = 'hello@ai-night.study';

const heroImage = '/assets/photo_2026-05-29_18-47-27.jpg';
const bookclubHref = 'https://www.instagram.com/p/DZkCcupEZOb/?img_index=1';
const profileImage = '/assets/nomad-profile-square.webp';

const gallery = [
  { src: '/assets/namhae-vibe-coding-workshop.webp', variant: 'poster', href: 'https://www.instagram.com/p/DWNulOLk-ax/?img_index=3', alt: '남해 청년센터 바이브 코딩 워크숍 안내 이미지' },
  { src: '/assets/ai-yahak-workshop-session.webp', variant: 'standard', alt: 'AI 야학 강의 현장' },
  { src: '/assets/ai-yahak-metal-room-session.webp', variant: 'portrait', alt: '금속 벽 강의장에서 진행한 AI 야학 현장' },
  { src: '/assets/photo_2026-06-16_17-36-00.jpg', variant: 'standard', alt: '참가자와 함께한 현장' },
  { src: '/assets/photo_2026-06-02_22-17-02.jpg', variant: 'standard', alt: '라운지 그룹 세션' },
  { src: '/assets/ai-bookclub.png', variant: 'poster', href: bookclubHref, alt: 'AI 야학 독서클럽 인스타그램 포스터' },
  { src: '/assets/DSC05866.jpg', variant: 'landscape', alt: '강의실 참가자' },
  { src: '/assets/DSC05669.jpg', variant: 'portrait', alt: '강의 연단 발표' },
  { src: '/assets/DSC07506.jpg', variant: 'landscape', alt: '패널 토크 현장' },
  { src: '/assets/ai-yahak-recruit.png', variant: 'poster', alt: 'AI 야학 참여자 모집 포스터' },
  { src: '/assets/WhatsApp_Image_2026-03-20_at_19.16.32.jpg', variant: 'standard', alt: '워크숍 네트워킹 현장' },
  { src: '/assets/photo_2024-11-13_14-09-03.jpg', variant: 'standard', alt: '무대 대담 현장' },
  { src: '/assets/onboarding-cheongdo.jpg', variant: 'poster', alt: '고향올래 온보딩청도 — 내 아이디어를 AI로 구현해보는 워크숍 포스터' },
  { src: '/assets/photo_2025-01-25_14-56-40.jpg', variant: 'portrait', alt: '컨퍼런스 발표 현장' },
];
const galleryLoop = [...gallery, ...gallery, ...gallery];
const journey = [
  {
    step: '01',
    head: '내 일 가져오기',
    body: '지난주에 손으로 쓴 보고서, 다음달 모집 공고, 매주 도는 정산표. 추상적인 예제가 아니라 본인 업무 파일을 들고 옵니다.',
  },
  {
    step: '02',
    head: '함께 만들기',
    body: '강사가 옆에서, 동기들이 옆에서. 코호트 단위로 같은 시간에 같은 문제를 푸는 야학 방식. 막힌 곳은 그 자리에서 풀어냅니다.',
  },
  {
    step: '03',
    head: '다음날 현장 적용',
    body: '강의실에서 만든 결과물은 다음날 사무실에서 그대로 씁니다. 강의 끝나면 사라지는 슬라이드가 아니라, 책상에 남는 도구를 만듭니다.',
  },
];

const programTracks = [
  {
    title: '정부지원사업 기획서·발표자료 만들기',
    body: '사업 아이템을 심사 언어로 정리합니다.',
    outputs: ['로컬 맞춤형 BM 분석', '정부지원사업 HWP 기획서 초안', '발표자료·심사 대응 문장'],
  },
  {
    title: '인스타·블로그·숏폼 콘텐츠 만들기',
    body: '매장과 상품을 바로 홍보할 콘텐츠로 바꿉니다.',
    outputs: ['인스타그램·블로그 발행 캘린더', '스마트폰 촬영 기반 숏폼 초안', '상세페이지·펀딩 스토리 구조'],
  },
  {
    title: '반복 업무 AI에게 맡기기',
    body: '혼자 반복하던 일을 맡길 AI 흐름을 만듭니다.',
    outputs: ['Notion·NotebookLM 업무 매뉴얼', '카카오톡 채널 FAQ 응대 흐름', '예약·위치·영업시간 반복 문의 자동화'],
  },
  {
    title: '영수증·정산·결과보고서 정리',
    body: '영수증과 보고서 사이의 시간을 줄입니다.',
    outputs: ['OCR 기반 영수증 정리', '지출 항목 분류', '결과보고서·정산보고서 초안'],
  },
  {
    title: '로컬 투어·체험 프로그램 기획',
    body: '지역의 이야기와 공간을 체험 상품으로 만듭니다.',
    outputs: ['마을 아카이브 정리', '로컬 투어 동선 설계', '가이드 시나리오·체험 프로그램 초안'],
  },
];

const expertiseGroups = [
  {
    label: '테크 업계 최전선 근무 경험',
    headline: '테크 업계의 변화 속에서, 현장에 필요한 적용 방식을 익혀 왔습니다.',
    items: [
      { text: '테크 업계 8년+ 근무' },
      { text: '전) 글로벌 테크 스타트업 APAC 지역 매니저' },
      { text: '모두의연구소 <AI 데이터 사이언티스트> 과정 수료', href: 'https://aiffel.io/' },
      { text: 'Anthropic Claude 공식 코스 수료', href: 'https://anthropic.skilljar.com/' },
    ],
  },
  {
    label: '실무형 수업 운영 경력',
    headline: '비전공자와 실무자가 따라오는 AI 수업을 운영했습니다.',
    items: [
      { text: '남해 청년센터 <바이브코딩> 워크숍', href: 'https://www.instagram.com/p/DWNulOLk-ax/?img_index=1' },
      { text: '경북 청도 <AI 온보딩> 및 <AI와 함께 일하는 방법을 배우는 4주 : AI 야학> 운영', href: 'https://gbcommons.org/' },
      { text: '비수도권 지역 소상공인 1:1 AI 컨설팅 진행' },
    ],
  },
  {
    label: '커뮤니티형 프로그램 운영 경력',
    headline: '사람이 모이고 배우는 장을 직접 만들고 운영했습니다.',
    items: [
      { text: '디지털 노마드를 위한 동아시아 소프트랜딩 서비스 <로컬노마드> 대표', href: 'https://localnomad.club/' },
      { text: '노마드 커뮤니티 팝업 마을 <ProtoVille> 운영', href: 'https://protoville.xyz/' },
      { text: '전) 프론티어 테크 코리빙·코워킹 커뮤니티 <nonce> 운영팀', href: 'https://nonce.community/' },
    ],
  },
];

const supportingCredentials = [
  { text: '<코리안 노마드의 출근길 뉴스레터> 연재 중', href: 'https://maily.so/asthedaysgoby' },
  { text: '연세대학교 경영학과 졸업' },
  { text: 'LinkedIn', href: 'https://www.linkedin.com/in/gen1234/' },
];

const quotes = [
  {
    body: 'AI에게 단순히 명령을 입력하는 것이 아니라, 원하는 결과를 얻기 위해 어떻게 질문하고 요청해야 하는지 배울 수 있었던 유익한 시간이었습니다. 그동안 AI가 어렵고 막연하게 느껴졌는데, 이번 강의를 통해 보다 친숙하게 다가갈 수 있었고 앞으로 실생활과 업무에도 적극 활용해보고 싶다는 생각이 들었습니다.',
    by: '경북시민재단 기획실 PM',
  },
  {
    body: '시골에서 부모님과 작은 사업을 운영하고 있는데 홍보 및 운영, 관리의 자동화에 전혀 신경 쓰지 않고 그냥 흘러가는대로 지내다 우연한 기회에 수업을 알고 듣게 되었습니다. 기대했던 것보다 훨씬 좋은 배움이었습니다. 저희 지역 특징을 살린 사업 홍보, 고객 응대 및 예약 자동화 등의 업무를 AI를 통해 보다 수월히 할 수 있게 되었고, 강사님도 완전 초보인 제가 잘 따라올 수 있도록 반복적으로 친절하게 잘 알려주셨습니다. 앞으로도 활용가능한 툴의 기초를 잡을 수 있는 훌륭한 경험이었습니다.',
    by: '전북 무주 자영업자',
  },
  {
    body: '수업 평가와 자료 개발에 AI를 적용하는 방법을 배우면서, 수업 준비에 드는 품과 시간을 줄이면서도 더 풍성한 수업을 준비할 수 있다는 가능성을 경험했습니다. 아직은 걸음마 단계이지만, 이번 강의를 통해 AI 활용을 조금씩 연습하고 확장해 갈 수 있는 기반을 다질 수 있었습니다. 앞으로 수업을 비롯한 삶의 여러 영역에서 AI에게 적절히 도움을 받을 수 있다면, 피로감을 덜고 보다 현명하게 삶을 운영해 나갈 수 있으리라 기대합니다.',
    by: '서울시 교사',
  },
];

const sections = [
  { id: 'difference', label: '운영 방식' },
  { id: 'outputs', label: '교육 주제' },
  { id: 'studio', label: '현장 사례' },
  { id: 'voices', label: '참가자 후기' },
  { id: 'expertise', label: '강사 소개' },
  { id: 'form', label: '문의' },
];
---

<Base
  title="AI 야학 — 로컬 비즈니스를 위한 실전 AI 교육"
  description="기획서부터 홍보 콘텐츠, 고객 응대, 반복 업무까지. 작은 사업자가 매일 마주치는 일을 AI로 덜어내는 실습형 교육."
>
  <header class="masthead">
    <div class="masthead-inner">
      <a href="/" class="masthead__wordmark" aria-label="AI 야학 홈">
        <img src="/favicon.svg" alt="" width="34" height="34" />
        <span>AI 야학</span>
      </a>
      <nav class="masthead__nav" aria-label="섹션 이동">
        {sections.slice(0, 5).map((s) => (
          <a href={`#${s.id}`}>{s.label}</a>
        ))}
      </nav>
      <a class="masthead__cta" href={ctaHref} target="_blank" rel="noreferrer" data-ga="cta" data-loc="nav">상담 예약</a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__bg" role="img" aria-label="AI 야학 현장">
        <img src={heroImage} alt="" loading="eager" fetchpriority="high" />
        <div class="hero__veil"></div>
      </div>

      <div class="hero__inner">
        <h1 id="hero-title">
          로컬 비즈니스를 위한<br/>
          <em>AI 야학</em>
        </h1>
        <p class="hero__sub">
          기획서부터 홍보 콘텐츠, 고객 응대, 반복 업무까지.
          작은 사업자가 매일 마주치는 일을<br/>
          <strong>AI로 덜어내는 실습형 교육</strong>입니다.
        </p>

        <div class="hero__cta">
          <a class="btn btn--primary" href={ctaHref} target="_blank" rel="noreferrer" data-ga="cta" data-loc="hero">
            15분 상담 예약하기 →
          </a>
        </div>

      </div>
    </section>

    <div class="shell">
      <!-- Difference -->
      <section id="difference" aria-labelledby="difference-title">
        <span class="eyebrow">운영 방식</span>
        <h2 id="difference-title">내 사업 자료로 시작해, 결과물로 끝납니다.</h2>
        <p class="lede">
          챗GPT 사용법을 배우는 시간이 아닙니다.
          참가자의 실제 사업 자료를 가져와서 강의실 안에서 결과물까지 만듭니다.
        </p>

        <ol class="journey">
          {journey.map((j) => (
            <li class="journey__step">
              <div class="journey__num">{j.step}</div>
              <h3>{j.head}</h3>
              <p>{j.body}</p>
            </li>
          ))}
        </ol>

        <p class="footnote">
          1일 워크숍부터 3-4회 코호트까지, 참여자 수준에 맞춰 실습과 피드백 시간을 조정합니다.
        </p>
      </section>

      <!-- Outputs -->
      <section id="outputs" aria-labelledby="outputs-title">
        <span class="eyebrow">교육 주제</span>
        <h2 id="outputs-title">참가자의 업무와 필요에 맞춰 수업을 설계합니다.</h2>
        <p class="lede">
          로컬 창업, 소상공인 디지털 전환, 로컬브랜드 고도화 사업에 맞춰
          필요한 트랙만 골라 1일 워크숍, 코호트, 마켓톤으로 설계합니다.
        </p>
        <ul class="program-grid">
          {programTracks.map((program, i) => (
            <li class="program-card">
              <div class="program-card__num">{String(i + 1).padStart(2, '0')}</div>
              <h3>{program.title}</h3>
              <p>{program.body}</p>
              <ul class="program-card__outputs">
                {program.outputs.map((output) => (
                  <li>{output}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
        <p class="footnote">
          필요한 트랙만 골라 구성합니다. 기준은 강의 목차가 아니라 참가자가 가져갈 결과물입니다.
        </p>
      </section>
    </div>

    <!-- Studio / gallery -->
    <section id="studio" class="studio" aria-labelledby="studio-title">
      <div class="studio__head">
        <span class="eyebrow eyebrow--dark">현장 사례</span>
        <h2 id="studio-title">한국에서, 해외에서. 이미 쌓아온 강의 현장입니다.</h2>
        <p class="lede">
          공공기관·대학·로컬 창업가 워크숍부터 해외 컨퍼런스 무대까지.
          다양한 청중 앞에서 다져온 강의 경험을 그대로 가져옵니다.
        </p>
      </div>
      <div class="studio__carousel" role="region" aria-label="강의 현장 사진">
        <button class="studio__arrow studio__arrow--prev" type="button" aria-label="이전 사진" data-carousel-prev>‹</button>
        <div class="studio__track" tabindex="0" aria-label="강의 현장 사진 목록" data-loop-size={gallery.length}>
          {gallery.map((item, i) => (
            <figure class={`studio__cell studio__cell--${item.variant}`} data-carousel-cell>
              {item.href ? (
                <a class="studio__link" href={item.href} target="_blank" rel="noreferrer" aria-label="AI 북클럽 인스타그램 게시물 열기">
                  <img src={item.src} alt={item.alt} loading={i < 4 ? 'eager' : 'lazy'} />
                </a>
              ) : (
                <img src={item.src} alt={item.alt} loading={i < 4 ? 'eager' : 'lazy'} />
              )}
            </figure>
          ))}
          {galleryLoop.slice(gallery.length).map((item, i) => (
            <figure class={`studio__cell studio__cell--${item.variant}`} data-carousel-cell aria-hidden="true">
              {item.href ? (
                <a class="studio__link" href={item.href} target="_blank" rel="noreferrer" tabindex="-1">
                  <img src={item.src} alt="" loading={i < 4 ? 'eager' : 'lazy'} />
                </a>
              ) : (
                <img src={item.src} alt="" loading={i < 4 ? 'eager' : 'lazy'} />
              )}
            </figure>
          ))}
        </div>
        <button class="studio__arrow studio__arrow--next" type="button" aria-label="다음 사진" data-carousel-next>›</button>
      </div>
    </section>

    <div class="shell">
      <!-- Quotes -->
      <section id="voices" aria-labelledby="voices-title">
        <span class="eyebrow">참가자 후기</span>
        <h2 id="voices-title">강의실을 나간 다음에 남는 것.</h2>

        <div class="quotes">
          {quotes.map((q) => (
            <figure class="quote">
              <blockquote>{q.body}</blockquote>
              <figcaption>— {q.by}</figcaption>
            </figure>
          ))}
        </div>
      </section>

      <!-- Expertise -->
      <section id="expertise" aria-labelledby="expertise-title">
        <span class="eyebrow">검증된 역량</span>
        <h2 id="expertise-title">현장에서 검증된 AI 실습 교육.</h2>
        <div class="expertise-layout">
          <div>
            <p class="lede">
              이력의 핵심은 이름 나열이 아니라, 로컬 현장에서 AI를 실제 업무 결과물로 바꿔본 경험입니다.
            </p>

            <div class="expertise-grid">
              {expertiseGroups.map((group, i) => (
                <article class="expertise-card" aria-labelledby={`expertise-group-${i}`}>
                  <div class="expertise-card__label">{group.label}</div>
                  <h3 id={`expertise-group-${i}`}>{group.headline}</h3>
                  <ul class="expertise-card__items">
                    {group.items.map((item) => (
                      <li>
                        {item.href ? (
                          <a href={item.href} target="_blank" rel="noreferrer">{item.text}</a>
                        ) : (
                          item.text
                        )}
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>

          </div>

          <figure class="profile-sidebar">
            <img src={profileImage} alt="AI 야학 강사 프로필 사진" loading="lazy" />
            <div class="profile-sidebar__body">
              <figcaption>
                <strong>이젠</strong>
                <span>5년차 디지털 노마드</span>
              </figcaption>
              <div class="profile-sidebar__credentials" aria-label="보조 이력">
                {supportingCredentials.map((item) => (
                  item.href ? (
                    <a href={item.href} target="_blank" rel="noreferrer">{item.text}</a>
                  ) : (
                    <span>{item.text}</span>
                  )
                ))}
              </div>
            </div>
          </figure>
        </div>
      </section>
    </div>

    <!-- Form -->
    <section id="form" class="form-section" aria-labelledby="form-title">
      <div class="form-shell">
        <span class="eyebrow eyebrow--dark">문의</span>
        <h2 id="form-title">우리 기관에 맞는 과정인지 15분만 확인해 보세요.</h2>
        <p class="lede lede--dark">
          대상, 일정, 예산, 참가자 수준을 짧게 듣고 맞는 운영 방식을 함께 정리합니다.
        </p>

        <a class="btn btn--primary btn--lg form-section__booking" href={ctaHref} target="_blank" rel="noreferrer" data-ga="cta" data-loc="form">
          15분 상담 예약하기 →
        </a>

        <details class="form-fallback">
          <summary>
            <span class="form-fallback__icon" aria-hidden="true">✉</span>
            <span class="form-fallback__label">이메일이 편하시면 여기로 남겨주세요</span>
          </summary>
          <form class="contact-form">
            <label class="contact-form__full">
              <span>이름</span>
              <input type="text" name="name" autocomplete="name" />
            </label>
            <label class="contact-form__full">
              <span>이메일</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label class="contact-form__full">
              <span>관심 있는 과정이나 상황 (선택)</span>
              <textarea name="pain" rows="2"></textarea>
            </label>
            <div class="contact-form__cta">
              <button type="submit" class="btn btn--primary">보내기</button>
            </div>
          </form>
        </details>
      </div>
    </section>
  </main>

  <footer aria-labelledby="footer-title">
    <div class="footer-inner">
      <h2 id="footer-title">AI 야학</h2>
      <p class="footer-tag">
        로컬 창업가와 소상공인이 AI로 더 가볍게 일할 수 있도록.
      </p>
      <div class="footer-links">
        <a href={`mailto:${mailAddr}`} data-ga="mail" data-loc="footer">{mailAddr}</a>
      </div>
    </div>
  </footer>

  <!-- Mobile sticky CTA -->
  <a href={ctaHref} class="sticky-cta" target="_blank" rel="noreferrer" data-ga="cta" data-loc="sticky">
    15분 상담 예약하기 →
  </a>

  <script>
    const stickyCta = document.querySelector('.sticky-cta');
    const hero = document.querySelector('.hero');
    const mailAddress = 'hello@ai-night.study';
    const updateStickyCta = () => {
      if (!stickyCta || !hero) return;
      const trigger = Math.min(hero.clientHeight * 0.72, 620);
      stickyCta.classList.toggle('is-visible', window.scrollY > trigger);
    };
    updateStickyCta();
    window.addEventListener('scroll', updateStickyCta, { passive: true });
    window.addEventListener('resize', updateStickyCta);

    const studioTrack = document.querySelector('.studio__track');
    const prev = document.querySelector('[data-carousel-prev]');
    const next = document.querySelector('[data-carousel-next]');
    let studioPausedUntil = 0;
    const getStudioLoopWidth = () => {
      if (!(studioTrack instanceof HTMLElement)) return 0;
      const loopSize = Number(studioTrack.dataset.loopSize) || 0;
      const cells = Array.from(studioTrack.querySelectorAll('[data-carousel-cell]')).slice(0, loopSize);
      if (!cells.length) return 0;
      const first = cells[0].getBoundingClientRect();
      const last = cells[cells.length - 1].getBoundingClientRect();
      return last.right - first.left;
    };
    const getStudioCellStep = () => {
      if (!(studioTrack instanceof HTMLElement)) return 0;
      const cells = studioTrack.querySelectorAll<HTMLElement>('[data-carousel-cell]');
      if (cells.length < 2) return 0;
      return cells[1].getBoundingClientRect().left - cells[0].getBoundingClientRect().left;
    };
    const syncStudioLoop = () => {
      if (!(studioTrack instanceof HTMLElement)) return;
      const loopWidth = getStudioLoopWidth();
      if (!loopWidth) return;
      if (studioTrack.scrollLeft < loopWidth * 0.5) {
        studioTrack.scrollLeft += loopWidth;
      } else if (studioTrack.scrollLeft > loopWidth * 1.5) {
        studioTrack.scrollLeft -= loopWidth;
      }
    };
    const scrollStudio = (dir: number) => {
      if (!(studioTrack instanceof HTMLElement)) return;
      syncStudioLoop();
      studioPausedUntil = Date.now() + 5000;
      const step = getStudioCellStep() || Math.min(studioTrack.clientWidth * 0.86, 720);
      studioTrack.scrollBy({ left: dir * step, behavior: 'smooth' });
    };
    prev?.addEventListener('click', () => scrollStudio(-1));
    next?.addEventListener('click', () => scrollStudio(1));
    studioTrack?.addEventListener('scrollend', syncStudioLoop);
    window.addEventListener('resize', () => {
      if (!(studioTrack instanceof HTMLElement)) return;
      const loopWidth = getStudioLoopWidth();
      if (loopWidth) studioTrack.scrollLeft = loopWidth;
    });
    requestAnimationFrame(() => {
      if (!(studioTrack instanceof HTMLElement)) return;
      const loopWidth = getStudioLoopWidth();
      if (loopWidth) studioTrack.scrollLeft = loopWidth;
    });
    studioTrack?.addEventListener('pointerenter', () => {
      studioPausedUntil = Date.now() + 2500;
    });
    setInterval(() => {
      if (!(studioTrack instanceof HTMLElement)) return;
      if (Date.now() < studioPausedUntil) return;
      syncStudioLoop();
      const step = getStudioCellStep();
      if (!step) return;
      studioTrack.scrollBy({ left: step, behavior: 'smooth' });
    }, 3200);

    const form = document.querySelector('.contact-form');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement)) return;
      const data = new FormData(form);
      const subject = encodeURIComponent('[AI 야학] 맞춤 교육 문의');
      const body = encodeURIComponent(
        [
          `이름: ${data.get('name') || ''}`,
          `이메일: ${data.get('email') || ''}`,
          '',
          `메모: ${data.get('pain') || ''}`,
        ].join('\n'),
      );
      window.location.href = `mailto:${mailAddress}?subject=${subject}&body=${body}`;
    });
  </script>
</Base>
