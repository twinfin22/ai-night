---
import type { OneActionTutorialDay } from '../data/course';
const { item } = Astro.props as { item: OneActionTutorialDay };
const clientPages = item.pages.map(({ source: _source, ...page }) => page);
---

<main class="one-action" data-one-action data-day={item.day} data-pages={JSON.stringify(clientPages)} data-storage={JSON.stringify({ version: 'ainight.version', done: 'ainight.done', position: 'ainight.position', last: 'ainight.last', app: 'ainight.app', draft: 'ainight.draft' })}>
  <section class="one-action__preflight" data-preflight hidden aria-labelledby="app-choice-title">
    <p class="eyebrow">수업 시작 전</p>
    <h1 id="app-choice-title">당신의 에이전트를<br />골라주세요</h1>
    <p class="one-action__preflight-intro">하나만 고르면, 그 에이전트에 맞는 수업을 보여드려요.</p>
    <fieldset class="one-action__app-options"><legend>나와 함께할 에이전트</legend>
      <label class="one-action__agent-card one-action__agent-card--codex"><input type="radio" name="app" value="codex" /><span class="one-action__agent-logo"><img src="/assets/tutorials/brands/openai.svg" alt="" width="38" height="38" /></span><span class="one-action__agent-copy"><small>OPENAI</small><strong>Codex</strong><span>작업 폴더 안의 파일을 직접 만들고 고쳐요.</span></span><span class="one-action__agent-select" aria-hidden="true"></span></label>
      <label class="one-action__agent-card one-action__agent-card--claude"><input type="radio" name="app" value="claude" /><span class="one-action__agent-logo"><img src="/assets/tutorials/brands/anthropic.svg" alt="" width="38" height="38" /></span><span class="one-action__agent-copy"><small>ANTHROPIC</small><strong>Claude</strong><span>대화와 자료를 바탕으로 생각을 정리해요.</span></span><span class="one-action__agent-select" aria-hidden="true"></span></label>
    </fieldset><button class="one-action__primary" type="button" data-start disabled>수업 시작</button>
  </section>
  <section class="one-action__shell" data-lesson hidden aria-label={`${item.day}일차 수업`}>
    <aside class="one-action__coach" data-coach>
      <header class="one-action__header"><a href="/tutorials/" class="one-action__brand" aria-label="AI 야학 수업 목록">AI 야학</a><strong title={`${item.day}일차 · ${item.title}`}><span>{item.day}일차</span> · {item.title}</strong><div class="one-action__progress" role="progressbar" aria-label="현재 수업 단계" aria-valuemin="1" data-progress><span data-progress-label>1 / {item.pages.length}</span></div></header>
      <div class="one-action__guide" data-guide><p class="one-action__eyebrow">지금 할 일</p><h1 tabindex="-1" data-title></h1><p data-description></p><strong data-action></strong><div data-guide-content></div><p class="one-action__status" data-status role="status" aria-live="polite"></p></div>
      <div class="one-action__support" data-support><div data-support-details></div><footer class="one-action__actions"><button type="button" data-prev>이전</button><button type="button" data-next>다음</button></footer></div>
    </aside>
    <section class="one-action__visual" data-visual aria-label="참고 화면"></section>
  </section>
</main>

<script>
  // @ts-nocheck
  import { runCourseMigrations } from '../lib/tutorial-progress';
  const root = document.querySelector('[data-one-action]');
  const pages = JSON.parse(root?.getAttribute('data-pages') || '[]');
  const day = Number(root?.getAttribute('data-day') || '0');
  const keys = JSON.parse(root?.getAttribute('data-storage') || '{}');
  try { runCourseMigrations(localStorage); } catch { /* memory-only lesson */ }
  const read = (storage, key, fallback) => { try { return JSON.parse(storage.getItem(key) || '') || fallback; } catch { return fallback; } };
  const write = (storage, key, value) => { try { storage.setItem(key, JSON.stringify(value)); return true; } catch { return false; } };
  const esc = (value) => String(value ?? '').replace(/[&<>'"]/g, (ch) => ({ '&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;' })[ch]);
  const preflight = root.querySelector('[data-preflight]'), lesson = root.querySelector('[data-lesson]');
  const start = root.querySelector('[data-start]'), appInput = root.querySelectorAll('input[name="app"]');
  let app = (() => { try { return localStorage.getItem(keys.app); } catch { return null; } })(), visible = [], index = 0, memoryDraft = {};
  const pageKey = () => visible[index]?.id;
  const drafts = () => ({ ...read(localStorage, keys.draft, {}), ...read(sessionStorage, keys.draft, {}), ...memoryDraft });
  const values = () => drafts()[pageKey()] || {};
  const saveValue = (control, value) => { const target = control.persist === 'session' ? sessionStorage : localStorage; const all = read(target, keys.draft, {}); all[pageKey()] = { ...(all[pageKey()] || {}), [control.id]: value }; if (!write(target, keys.draft, all)) memoryDraft = { ...memoryDraft, [pageKey()]: { ...(memoryDraft[pageKey()] || {}), [control.id]: value } }; };
  const getVisible = () => pages.filter((page) => !page.track || page.track === app).filter((page) => !page.visibleWhen || drafts()['d07-choice-output']?.[page.visibleWhen.choiceKey] === page.visibleWhen.equals);
  const selectedCount = (value) => Array.isArray(value) ? value.length : value ? 1 : 0;
  const controlsComplete = (page) => (page.controls || []).every((control) => { const count = selectedCount(values()[control.id]); return !(control.required && !count) && !(control.exact !== undefined && count !== control.exact) && !(control.min !== undefined && count < control.min) && !(control.max !== undefined && count > control.max); });
  const highlighted = (text, tokens = []) => tokens.reduce((html, token) => html.replaceAll(esc(token), `<mark>${esc(token)}</mark>`), esc(text));
  const controlHtml = (control, current) => {
    const name = `control-${esc(control.id)}`;
    if (control.type === 'text') return `<label class="guide-field"><span>${esc(control.label)}</span><textarea data-control="${esc(control.id)}" rows="3">${esc(current || '')}</textarea></label>`;
    const type = control.type === 'radio' ? 'radio' : 'checkbox'; const selected = Array.isArray(current) ? current : [current];
    return `<fieldset class="guide-choice"><legend>${esc(control.label)}</legend>${(control.options || []).map((option) => `<label><input data-control="${esc(control.id)}" type="${type}" name="${name}" value="${esc(option.value)}" ${selected.includes(option.value) ? 'checked' : ''}><strong>${esc(option.label)}</strong>${option.description ? `<span>${esc(option.description)}</span>` : ''}</label>`).join('')}</fieldset>`;
  };
  const promptVisual = (page) => page.prompt ? `<div class="visual-prompt"><pre><code>${highlighted(page.prompt, page.highlightTokens)}</code></pre></div>` : '';
  const imagesVisual = (images) => images?.length ? `<div class="visual-images">${images.map((image) => `<figure class="visual-image"><img src="${esc(image.src)}" alt="${esc(image.alt)}"></figure>`).join('')}</div>` : '';
  const guideLinks = (page) => `${page.prompt ? '<button type="button" class="one-action__primary" data-copy>복사하기</button>' : ''}${page.officialLinks?.length ? `<div class="guide-links" aria-label="공식 링크">${page.officialLinks.map((link) => `<a href="${esc(link.href)}" target="_blank" rel="noopener noreferrer"><strong>${esc(link.label)} <span aria-label="새 창">↗</span></strong><span>${esc(link.publisher)} · ${esc(link.verifiedAt)} 확인</span><small>${esc(link.accessNote)}</small></a>`).join('')}</div>` : ''}${page.downloadLinks?.length ? `<div class="guide-downloads" aria-label="자료 다운로드">${page.downloadLinks.map((link) => `<a href="${esc(link.href)}" download>${esc(link.label)} 다운로드</a>`).join('')}</div>` : ''}`;
  const visualHtml = (page) => {
    if (page.view === 'FOCUS') return `<div class="visual-focus">${page.subtitle ? `<p>${esc(page.subtitle)}</p>` : ''}${page.flow ? `<ol class="visual-timeline" data-timeline>${page.flow.map((part) => `<li><span aria-hidden="true"></span>${esc(part)}</li>`).join('')}</ol>` : ''}${page.outcome ? `<strong>결과물: ${esc(page.outcome)}</strong>` : ''}</div>`;
    if (page.view === 'COMPARISON') return `<div class="visual-comparison">${(page.comparison || []).map((part) => `<section><strong>${esc(part.label)}</strong><p>${esc(part.content)}</p></section>`).join('')}</div>`;
    return `${imagesVisual(page.images || (page.image ? [page.image] : []))}${promptVisual(page)}`;
  };
  const supportHtml = (page) => page.technicalDetails?.length ? `<details class="guide-details"><summary>안 보여요 · 보충 설명</summary>${page.technicalDetails.map((detail) => `<section><strong>${esc(detail.title)}</strong><p>${esc(detail.body)}</p></section>`).join('')}</details>` : '';
  const report = (message, alert = false) => { const status = root.querySelector('[data-status]'); status.textContent = message; status.setAttribute('role', alert ? 'alert' : 'status'); };
  const updateNext = (page = visible[index]) => { root.querySelector('[data-next]').disabled = !controlsComplete(page); };
  const renderContent = (page) => {
    const guide = root.querySelector('[data-guide-content]'), visual = root.querySelector('[data-visual]'), support = root.querySelector('[data-support-details]'), state = values();
    const controls = (page.controls || []).map((control) => controlHtml(control, state[control.id])).join('');
    const supporting = page.supporting && page.supporting !== page.description && page.supporting !== page.action ? `<p class="guide-supporting">${esc(page.supporting)}</p>` : '';
    guide.innerHTML = `${page.view === 'WORKBOOK' ? '<p class="guide-note">이 회고는 AI가 대신 쓰거나 평가하지 않습니다. 내 말로 작성하세요.</p>' : ''}${supporting}${controls}${guideLinks(page)}`;
    visual.dataset.view = page.view; visual.innerHTML = visualHtml(page); support.innerHTML = supportHtml(page);
    guide.querySelectorAll('[data-control]').forEach((input) => input.addEventListener('input', () => { const control = page.controls.find((item) => item.id === input.dataset.control); const value = control.type === 'checkbox' ? [...guide.querySelectorAll(`[data-control="${CSS.escape(control.id)}"]:checked`)].map((item) => item.value) : input.value; saveValue(control, value); if (page.kind === 'CHOICE') { const currentId = page.id; visible = getVisible(); index = Math.max(0, visible.findIndex((item) => item.id === currentId)); } updateNext(page); }));
    guide.querySelector('[data-copy]')?.addEventListener('click', async (event) => { const button = event.currentTarget; try { await navigator.clipboard.writeText(page.prompt || ''); button.textContent = '복사됨'; report('복사했습니다.'); } catch { button.textContent = '복사하지 못했습니다'; report('복사하지 못했습니다. 직접 선택해 복사해 주세요.', true); } });
    visual.querySelectorAll('img').forEach((image) => image.addEventListener('error', () => { image.closest('figure')?.remove(); report('스크린샷을 불러오지 못했습니다.', true); }));
  };
  const render = (focus = false) => { const page = visible[index]; if (!page) { root.querySelector('[data-guide-content]').innerHTML = '<div class="guide-recovery"><h2>열 수 있는 수업 화면이 없습니다.</h2><a href="/tutorials/">수업 목록으로</a></div>'; root.querySelector('[data-visual]').innerHTML = ''; report('수업 화면을 복구하지 못했습니다.', true); return; } root.querySelector('[data-title]').textContent = page.title; root.querySelector('[data-description]').textContent = page.description; root.querySelector('[data-action]').textContent = page.action || ''; root.querySelector('[data-progress-label]').textContent = `${index + 1} / ${visible.length}`; const progress = root.querySelector('[data-progress]'); progress.setAttribute('aria-valuemax', String(visible.length)); progress.setAttribute('aria-valuenow', String(index + 1)); root.querySelector('[data-prev]').disabled = index === 0; root.querySelector('[data-next]').textContent = index === visible.length - 1 ? '완료하기' : '다음'; renderContent(page); updateNext(page); const position = read(localStorage, keys.position, {}); position[`${day}.${app}`] = page.id; write(localStorage, keys.position, position); try { localStorage.setItem(keys.last, String(day)); } catch {} if (focus) root.querySelector('[data-title]').focus(); };
  const begin = () => { if (!app) return; try { localStorage.setItem(keys.app, app); } catch { report('진도를 저장하지 못해도 이 수업은 계속할 수 있습니다.', true); } visible = getVisible(); const saved = read(localStorage, keys.position, {})[`${day}.${app}`]; index = Math.max(0, visible.findIndex((page) => page.id === saved)); preflight.hidden = true; lesson.hidden = false; render(); };
  appInput.forEach((input) => input.addEventListener('change', () => { app = input.value; start.disabled = false; })); start?.addEventListener('click', begin);
  root.querySelector('[data-prev]')?.addEventListener('click', () => { index = Math.max(0, index - 1); render(true); });
  root.querySelector('[data-next]')?.addEventListener('click', () => { if (!controlsComplete(visible[index])) return; if (index < visible.length - 1) { index += 1; render(true); return; } const done = read(localStorage, keys.done, []).map(Number); if (!done.includes(day)) done.push(day); write(localStorage, keys.done, [...new Set(done)].sort((a, b) => a - b)); try { sessionStorage.setItem('ainight.completed', String(day)); } catch {} window.location.href = '/tutorials/'; });
  if (!pages.some((page) => page.track)) { app = 'common'; begin(); } else if (app === 'codex' || app === 'claude') begin(); else preflight.hidden = false;
</script>
