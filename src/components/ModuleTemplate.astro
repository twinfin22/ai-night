---
import Base from '../layouts/Base.astro';
import type { SummaryItem, TutorialStep } from '../data/tutorial-types';

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  markdownPath: string;
  steps: TutorialStep[];
  summary: SummaryItem[];
  resumePrompt: string;
  resumePromptByTrack?: {
    codex: string;
    claude: string;
  };
  toolSelector?: boolean;
  stepsLabel?: string;
  ctaLabel?: string;
}

const {
  title,
  description,
  canonicalPath,
  steps,
  summary,
  toolSelector = false,
  stepsLabel = `${steps.length}단계`,
  ctaLabel = '바로 시작',
} = Astro.props;
---

<Base title={`${title} — AI 야학`} description={description} canonicalPath={canonicalPath}>
  <header class="masthead module-nav">
    <div class="masthead-inner">
      <a href="/" class="masthead__wordmark" aria-label="AI 야학 홈">
        <img src="/favicon.svg" alt="" width="34" height="34" />
        <span>AI 야학</span>
      </a>
      <nav class="masthead__nav" aria-label="모듈 섹션 이동">
        <a href="#overview">시작</a>
        <a href="#steps">{stepsLabel}</a>
      </nav>
      <a class="masthead__cta" href="#steps">{ctaLabel}</a>
    </div>
  </header>

  <main class={toolSelector ? 'module-page module-page--tool-selector' : 'module-page'} data-tool-selector={toolSelector ? 'true' : undefined}>
    <section class="module-lesson-hero" aria-labelledby="module-title">
      <div class="module-lesson-hero__inner">
        <div>
          <span class="eyebrow">튜토리얼</span>
          <h1 id="module-title">{title}</h1>
        </div>
        {summary.length > 0 && (
          <aside class="module-summary" aria-label="모듈 요약">
            {summary.map((item) => (
              <div>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))}
          </aside>
        )}
      </div>
    </section>

    <div class="module-shell">
      <aside class="module-sidebar" aria-label="모듈 빠른 이동">
        <a href="#overview">전체 흐름</a>
        {steps.map((item) => (
          <a href={`#step-${item.step}`} data-track={item.track ?? 'both'}>{item.step}. {item.label}</a>
        ))}
      </aside>

      <div class="module-content">
        <section id="overview" class="module-panel" aria-labelledby="overview-title">
          <h2 id="overview-title">이번 튜토리얼에서 하는 일</h2>
          {toolSelector && (
            <div class="setup-selector" aria-labelledby="setup-selector-title">
              <h3 id="setup-selector-title">먼저 내 환경을 골라주세요.</h3>
              <div class="setup-selector__grid">
                <div>
                  <h4>컴퓨터</h4>
                  <div class="segmented-control" role="group" aria-label="운영체제 선택">
                    <button type="button" data-os-choice="mac">맥(Mac)</button>
                    <button type="button" data-os-choice="windows">윈도우(Windows)</button>
                  </div>
                </div>
                <div>
                  <h4>도구</h4>
                  <div class="segmented-control" role="group" aria-label="도구 선택">
                    <button type="button" data-tool-choice="codex">코덱스(Codex)</button>
                    <button type="button" data-tool-choice="claude">클로드(Claude)</button>
                  </div>
                </div>
              </div>
              <p class="setup-selector__hint">선택한 도구에 맞는 단계만 보여줍니다.</p>
            </div>
          )}
          <ol class="tutorial-flow">
            {steps.map((item) => (
              <li data-track={item.track ?? 'both'}>
                <a href={`#step-${item.step}`} data-track={item.track ?? 'both'}>
                  <span>{item.step}</span>
                  <strong>{item.label}</strong>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <section id="steps" class="module-panel" aria-labelledby="steps-title">
          <h2 id="steps-title">한 단계씩 열어서 따라가세요.</h2>

          <div class="lesson-steps">
            {steps.map((item, index) => {
              const track = item.track ?? 'both';

              return (
                <>
                  <details id={`step-${item.step}`} class="lesson-step" data-track={track} open={index === 0}>
                    <summary>
                      <span class="lesson-step__num">{item.step}</span>
                      <span class="lesson-step__main">
                        <strong>{item.label}</strong>
                        <em>{item.title}</em>
                      </span>
                    </summary>

                    <div class="lesson-step__body">
                  <p class="lesson-step__goal">{item.goal}</p>

                  {item.officialLinks?.length && (
                    <div class="lesson-meta">
                      {item.officialLinks?.map((link) => (
                        <a class="lesson-link" href={link.url} target="_blank" rel="noopener noreferrer" aria-label={`${link.label} 새 창으로 열기`}>
                          <span>공식 링크 / 새 창</span>
                          <strong>{link.label} 열기</strong>
                          <code>{link.url}</code>
                        </a>
                      ))}
                    </div>
                  )}

                  {(item.screenshots ?? []).length > 0 && (
                    <div class="tutorial-shots">
                      {(item.screenshots ?? []).map((shot) => (
                        <figure>
                          <a class="tutorial-shot-link" href={shot.src} target="_blank" rel="noreferrer" aria-label={`${shot.alt} 크게 열기`}>
                            <img src={shot.src} alt={shot.alt} loading="lazy" />
                          </a>
                          <figcaption>{shot.caption}</figcaption>
                        </figure>
                      ))}
                    </div>
                  )}

                  <div class="skill-strip">
                    {item.recommended.length > 0 && (
                      <div>
                        <span>추천 스킬</span>
                        <ul class="skill-strip__cmds">{item.recommended.map((skill) => <li>{skill}</li>)}</ul>
                      </div>
                    )}
                    {item.useful.length > 0 && (
                      <div>
                        <span>같이 쓰면 좋은 기능</span>
                        <ul>{item.useful.map((skill) => <li>{skill}</li>)}</ul>
                      </div>
                    )}
                  </div>

                  <p class="lesson-step__output"><span>이 단계 결과물</span>{item.output}</p>

                  {(item.successCriteria ?? []).length > 0 && (
                    <div class="success-box">
                      <h3>끝났는지 확인</h3>
                      <ul>
                        {(item.successCriteria ?? []).map((criterion) => <li>{criterion}</li>)}
                      </ul>
                    </div>
                  )}

                  {(item.conceptToggles ?? []).length > 0 && (
                    <div class="concept-toggles">
                      {(item.conceptToggles ?? []).map((concept) => (
                        <details>
                          <summary>{concept.title}</summary>
                          <p>{concept.body}</p>
                        </details>
                      ))}
                    </div>
                  )}

                  {item.recoveryPrompt && (
                    <details class="prompt-toggle">
                      <summary>
                        <span>막혔을 때</span>
                      </summary>
                      <div class="prompt-toggle__body">
                        <button type="button" data-copy-prompt aria-live="polite">복사하기</button>
                        <pre><code>{item.recoveryPrompt}</code></pre>
                      </div>
                    </details>
                  )}

                  {item.prompt && (
                    <details class="prompt-toggle">
                      <summary>
                        <span>복붙 프롬프트</span>
                      </summary>
                      <div class="prompt-toggle__body">
                        <button type="button" data-copy-prompt aria-live="polite">복사하기</button>
                        <pre><code>{item.prompt}</code></pre>
                      </div>
                    </details>
                  )}
                    </div>
                  </details>
                </>
              );
            })}
          </div>
        </section>

      </div>
    </div>
  </main>

  <script>
    const setupRoot = document.querySelector('[data-tool-selector]');

    const applySetupChoice = () => {
      const selectedTool = window.localStorage.getItem('setup-tool') || '';
      const selectedOs = window.localStorage.getItem('setup-os') || '';

      if (setupRoot && selectedTool) {
        document.documentElement.dataset.setupTool = selectedTool;
      } else {
        delete document.documentElement.dataset.setupTool;
      }

      if (setupRoot && selectedOs) {
        document.documentElement.dataset.setupOs = selectedOs;
      } else {
        delete document.documentElement.dataset.setupOs;
      }

      document.querySelectorAll('[data-tool-choice]').forEach((button) => {
        button.toggleAttribute('aria-pressed', button.getAttribute('data-tool-choice') === selectedTool);
      });

      document.querySelectorAll('[data-os-choice]').forEach((button) => {
        button.toggleAttribute('aria-pressed', button.getAttribute('data-os-choice') === selectedOs);
      });
    };

    document.querySelectorAll('[data-tool-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        window.localStorage.setItem('setup-tool', button.getAttribute('data-tool-choice') || '');
        applySetupChoice();
      });
    });

    document.querySelectorAll('[data-os-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        window.localStorage.setItem('setup-os', button.getAttribute('data-os-choice') || '');
        applySetupChoice();
      });
    });

    applySetupChoice();

    const copyButtons = document.querySelectorAll('[data-copy-prompt]');

    const fallbackCopy = (text: string) => {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.left = '-9999px';
      document.body.appendChild(textarea);
      textarea.select();
      (document as any).execCommand('copy');
      textarea.remove();
    };

    copyButtons.forEach((button) => {
      button.addEventListener('click', async (event) => {
        event.preventDefault();
        event.stopPropagation();
        if (!(button instanceof HTMLButtonElement)) return;
        const prompt = button.closest('.prompt-toggle')?.querySelector('code')?.textContent || '';
        if (!prompt.trim()) return;

        try {
          if (navigator.clipboard?.writeText) {
            try {
              await navigator.clipboard.writeText(prompt);
            } catch {
              fallbackCopy(prompt);
            }
          } else {
            fallbackCopy(prompt);
          }
          const original = button.textContent || '복사하기';
          button.textContent = '복사됨';
          window.setTimeout(() => {
            button.textContent = original;
          }, 1400);
        } catch {
          button.textContent = '복사 실패';
          window.setTimeout(() => {
            button.textContent = '복사하기';
          }, 1400);
        }
      });
    });
  </script>
</Base>
