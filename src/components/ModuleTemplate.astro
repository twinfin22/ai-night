---
import Base from '../layouts/Base.astro';
import type { SummaryItem, TutorialStep } from '../data/tutorial-types';

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  markdownPath: string;
  steps: TutorialStep[];
  summary: SummaryItem[];
  prepItems: string[];
  prepNote: string;
  resumePrompt: string;
  stepsLabel?: string;
  ctaLabel?: string;
}

const {
  title,
  description,
  canonicalPath,
  markdownPath,
  steps,
  summary,
  prepItems,
  prepNote,
  resumePrompt,
  stepsLabel = `${steps.length}단계`,
  ctaLabel = '바로 시작',
} = Astro.props;
---

<Base title={`${title} — AI 야학`} description={description} canonicalPath={canonicalPath}>
  <header class="masthead module-nav">
    <div class="masthead-inner">
      <a href="/" class="masthead__wordmark" aria-label="AI 야학 홈">
        <img src="/favicon.svg" alt="" width="34" height="34" />
        <span>AI 야학</span>
      </a>
      <nav class="masthead__nav" aria-label="모듈 섹션 이동">
        <a href="#start">시작</a>
        <a href="#steps">{stepsLabel}</a>
      </nav>
      <a class="masthead__cta" href="#steps">{ctaLabel}</a>
    </div>
  </header>

  <main class="module-page">
    <section class="module-lesson-hero" aria-labelledby="module-title">
      <div class="module-lesson-hero__inner">
        <div>
          <span class="eyebrow">튜토리얼</span>
          <h1 id="module-title">{title}</h1>
        </div>
        <aside class="module-summary" aria-label="모듈 요약">
          {summary.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <div class="module-shell">
      <aside class="module-sidebar" aria-label="모듈 빠른 이동">
        <a href="#start">시작 전 준비</a>
        <a href="#overview">전체 흐름</a>
        {steps.map((item) => (
          <a href={`#step-${item.step}`}>{item.step}. {item.label}</a>
        ))}
        <a href="#resume">중간에 멈출 때</a>
      </aside>

      <div class="module-content">
        <section id="start" class="module-panel" aria-labelledby="start-title">
          <h2 id="start-title">먼저 이것만 준비하세요.</h2>
          <ul class="prep-list">
            {prepItems.map((item) => <li>{item}</li>)}
          </ul>
          <div class="module-note">
            <strong>중요:</strong>
            {prepNote}
          </div>
        </section>

        <section id="overview" class="module-panel" aria-labelledby="overview-title">
          <h2 id="overview-title">이번 튜토리얼에서 하는 일</h2>
          <p class="module-panel__intro">사람이 확인하고 결정하는 순서입니다. AI가 할 일은 각 단계 안에 같이 넣었습니다.</p>
          <ol class="tutorial-flow">
            {steps.map((item) => (
              <li>
                <a href={`#step-${item.step}`}>
                  <span>{item.step}</span>
                  <strong>{item.label}</strong>
                </a>
              </li>
            ))}
          </ol>
          <details class="module-ai-note">
            <summary>AI에게 이 페이지를 줄 때</summary>
            <p>
              이 튜토리얼 전체를 텍스트로 넘기려면 <a href={markdownPath}>{markdownPath}</a> 주소를 사용하세요.
            </p>
          </details>
        </section>

        <section id="steps" class="module-panel" aria-labelledby="steps-title">
          <h2 id="steps-title">한 단계씩 열어서 따라가세요.</h2>

          <div class="lesson-steps">
            {steps.map((item, index) => (
              <details id={`step-${item.step}`} class="lesson-step" open={index === 0}>
                <summary>
                  <span class="lesson-step__num">{item.step}</span>
                  <span class="lesson-step__main">
                    <strong>{item.label}</strong>
                    <em>{item.title}</em>
                  </span>
                </summary>

                <div class="lesson-step__body">
                  <p class="lesson-step__goal">{item.goal}</p>

                  {(item.learner.length > 0 || item.ai.length > 0) && (
                    <div class="lesson-columns">
                      {item.learner.length > 0 && (
                        <div>
                          <h3>내가 할 일</h3>
                          <ul>
                            {item.learner.map((task) => <li>{task}</li>)}
                          </ul>
                        </div>
                      )}
                      {item.ai.length > 0 && (
                        <div>
                          <h3>AI에게 맡길 일</h3>
                          <ul>
                            {item.ai.map((task) => <li>{task}</li>)}
                          </ul>
                        </div>
                      )}
                    </div>
                  )}

                  <div class="skill-strip">
                    {item.recommended.length > 0 && (
                      <div>
                        <span>추천 스킬</span>
                        <ul class="skill-strip__cmds">{item.recommended.map((skill) => <li>{skill}</li>)}</ul>
                      </div>
                    )}
                    {item.useful.length > 0 && (
                      <div>
                        <span>같이 쓰면 좋은 기능</span>
                        <ul>{item.useful.map((skill) => <li>{skill}</li>)}</ul>
                      </div>
                    )}
                  </div>

                  <p class="lesson-step__output"><span>이 단계 결과물</span>{item.output}</p>

                  {item.prompt && (
                    <details class="prompt-toggle">
                      <summary>
                        <span>복붙 프롬프트</span>
                        <button type="button" data-copy-prompt aria-live="polite">복사하기</button>
                      </summary>
                      <pre><code>{item.prompt}</code></pre>
                    </details>
                  )}
                </div>
              </details>
            ))}
          </div>
        </section>

        <section id="resume" class="module-panel" aria-labelledby="resume-title">
          <h2 id="resume-title">중간에 끊기면 이것만 남기세요.</h2>
          <details class="prompt-toggle prompt-toggle--standalone">
            <summary>
              <span>다음에 이어가기 프롬프트</span>
              <button type="button" data-copy-prompt aria-live="polite">복사하기</button>
            </summary>
            <pre><code>{resumePrompt}</code></pre>
          </details>
        </section>
      </div>
    </div>
  </main>

  <script>
    const copyButtons = document.querySelectorAll('[data-copy-prompt]');

    const fallbackCopy = (text: string) => {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.left = '-9999px';
      document.body.appendChild(textarea);
      textarea.select();
      (document as any).execCommand('copy');
      textarea.remove();
    };

    copyButtons.forEach((button) => {
      button.addEventListener('click', async (event) => {
        event.preventDefault();
        event.stopPropagation();
        if (!(button instanceof HTMLButtonElement)) return;
        const prompt = button.closest('.prompt-toggle')?.querySelector('code')?.textContent || '';
        if (!prompt.trim()) return;

        try {
          if (navigator.clipboard?.writeText) {
            try {
              await navigator.clipboard.writeText(prompt);
            } catch {
              fallbackCopy(prompt);
            }
          } else {
            fallbackCopy(prompt);
          }
          const original = button.textContent || '복사하기';
          button.textContent = '복사됨';
          window.setTimeout(() => {
            button.textContent = original;
          }, 1400);
        } catch {
          button.textContent = '복사 실패';
          window.setTimeout(() => {
            button.textContent = '복사하기';
          }, 1400);
        }
      });
    });
  </script>
</Base>
